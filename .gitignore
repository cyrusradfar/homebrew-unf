# Generated by Cargo
# will have compiled files and executables
debug/
target/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# Claude Code (private development config)
.claude/

# RustRover
#.idea/

# Python bytecode (from test fixtures)
__pycache__/
*.pyc

# Tauri app build artifacts
app/ui/node_modules/
app/ui/dist/
app/gen/

# Secrets and certificates
keys/
*.p12
*.pem
*.cer

# CloudFront log cache (download stats)
.download-logs/
